# ============================================================
# City Girl — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# ── WhatsApp ─────────────────────────────────────────────────
# Your WhatsApp number in international format (no + sign)
# Example: 919876543210  (91 = India country code)
REACT_APP_SELLER_WHATSAPP=13522841454

# ── Backend API (add when you build the Node.js backend) ─────
REACT_APP_API_URL=http://localhost:5000

# ── AWS S3 (frontend only needs the base URL) ────────────────
# Example: https://city-girl-sarees.s3.ap-south-1.amazonaws.com
REACT_APP_S3_BASE_URL=https://YOUR-BUCKET.s3.ap-south-1.amazonaws.com
